<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Админ-панель</title>
    <link rel="stylesheet" href="~/css/site.css" />
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    <header>
        <nav class="navbar">
            <div class="navbar-brand">
                <a asp-controller="Dashboard" asp-action="Index">Админ-панель</a>
            </div>
            <ul class="navbar-menu">
                @if (User.Identity?.IsAuthenticated == true)
                {
                    <li><a asp-controller="Dashboard" asp-action="Index">Главная</a></li>
                    <li><a asp-controller="Managers" asp-action="Index">Управление менеджерами</a></li>
                    <li>
                        <form asp-controller="Account" asp-action="Logout" method="post" class="logout-form">
                            <button type="submit" class="logout-btn">Выход (@User.Identity?.Name)</button>
                        </form>
                    </li>
                }
            </ul>
        </nav>
    </header>

    <main class="container">
        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success">
                @TempData["Success"]
            </div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="alert alert-error">
                @TempData["Error"]
            </div>
        }
        @RenderBody()
    </main>

    <footer class="footer">
        <div class="container">
            <span>&copy; @DateTime.Now.Year - Админ-панель Personal Cabinet Uni</span>
        </div>
    </footer>

    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
